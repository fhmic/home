{
  "_meta": {
    "title": "FSCF Treasury Intelligence — API Schema & Reference",
    "version": "1.0.0",
    "baseUrl": "https://eis-recbackend.onrender.com",
    "auth": "Bearer <JWT token from /api/treasury/auth/login>"
  },

  "endpoints": {
    "auth": {
      "POST /api/treasury/auth/register": {
        "body":     { "name":"string", "email":"string", "password":"string", "role":"admin|analyst|viewer" },
        "response": { "token":"string", "user":{ "name":"string", "email":"string", "role":"string" } }
      },
      "POST /api/treasury/auth/login": {
        "body":     { "email":"string", "password":"string" },
        "response": { "token":"string", "user":{ "name":"string", "email":"string", "role":"string" } }
      }
    },
    "dashboard": {
      "GET /api/treasury/dashboard": {
        "auth": true,
        "response": {
          "asAt": "ISO date",
          "kpis": {
            "totalCashNGN":        "number (₦M)",
            "netLiquidity":        "number (₦M)",
            "loanBookSize":        "number (₦M)",
            "eclProvision":        "number (₦M)",
            "eclCoverage":         "number (%)",
            "totalBorrowings":     "number (₦M)",
            "investmentPortfolio": "number (₦M)",
            "nplRatio":            "number (%)",
            "wacd":                "number (%)"
          },
          "stageDistribution": [{ "stage":1, "count":0, "ead":0, "ecl":0 }]
        }
      }
    },
    "loans": {
      "GET /api/treasury/loans": {
        "auth": true,
        "query": { "stage":"1|2|3", "product":"string", "status":"active|settled|written-off" }
      },
      "POST /api/treasury/loans": { "auth":true, "body": "LoanDocument" },
      "PUT /api/treasury/loans/:loanId": { "auth":true, "body": "Partial<LoanDocument>" },
      "DELETE /api/treasury/loans/:loanId": { "auth":true },
      "POST /api/treasury/loans/upload": {
        "auth": true,
        "contentType": "multipart/form-data",
        "field": "file",
        "accepted": ".csv, .xlsx",
        "csvColumns": ["loan_id","customer_name","loan_product_type","principal_amount","interest_rate","start_date","maturity_date","days_past_due","credit_rating"],
        "response": { "inserted":0, "errors":[] }
      }
    },
    "ecl": {
      "GET /api/treasury/ecl": {
        "auth": true,
        "query": { "pdMultiplier":"number (default 1.0 — use e.g. 1.25 for +25% PD stress)" },
        "response": {
          "totalECL":      "number (₦M)",
          "totalEAD":      "number (₦M)",
          "coverageRatio": "number (%)",
          "byStage":       [{ "stage":1, "count":0, "ead":0, "ecl":0 }],
          "loans":         [{ "loanId":"string", "stage":1, "ead":0, "pd":0.02, "lgd":0.45, "ecl":0, "eclRate":0 }]
        }
      },
      "POST /api/treasury/ecl/scenario": {
        "auth": true,
        "body": { "pdShiftPct": "number (e.g. 25 for +25%, -20 for -20%)" }
      }
    },
    "borrowings": {
      "GET /api/treasury/borrowings": { "auth":true },
      "POST /api/treasury/borrowings": { "auth":true, "body": "BorrowingDocument" },
      "POST /api/treasury/borrowings/upload": {
        "auth": true,
        "contentType": "multipart/form-data",
        "field": "file",
        "csvColumns": ["borrowing_id","lender_name","borrowing_type","principal","interest_rate","tenor_months","repayment_schedule","maturity_date"]
      }
    },
    "investments": {
      "GET /api/treasury/investments": { "auth":true },
      "POST /api/treasury/investments": { "auth":true, "body": "InvestmentDocument" },
      "POST /api/treasury/investments/upload": {
        "auth": true,
        "contentType": "multipart/form-data",
        "field": "file",
        "csvColumns": ["investment_id","company_name","investment_type","principal_amount","interest_rate","date_invested","number_of_days"]
      }
    },
    "cash": {
      "GET /api/treasury/cash": { "auth":true },
      "POST /api/treasury/cash": { "auth":true, "body": "CashAccountDocument" },
      "PATCH /api/treasury/cash/:accountId/balance": {
        "auth": true,
        "body": { "balance": "number" }
      }
    },
    "health": {
      "GET /api/treasury/health": { "auth":false }
    }
  },

  "schemas": {
    "Loan": {
      "loanId":       "string (required, unique) — e.g. LN-001",
      "customer":     "string (required)",
      "product":      "Invoice Discounting | Supply Chain Finance | Factoring | Reverse Factoring",
      "principal":    "number (₦M, required)",
      "outstanding":  "number (₦M, required)",
      "interestRate": "number (%, required)",
      "startDate":    "ISO date (required)",
      "maturityDate": "ISO date (required)",
      "daysPastDue":  "number (default 0) — stage auto-derived: 0-29→S1, 30-89→S2, 90+→S3",
      "creditRating": "string (default NR)",
      "stage":        "1|2|3 (auto-set from daysPastDue on save)",
      "status":       "active | settled | written-off (default active)"
    },
    "Borrowing": {
      "borrowingId":  "string (required, unique) — e.g. BW-001",
      "lender":       "string (required)",
      "type":         "Term Loan | Overdraft Facility | On-lending Facility | SME Fund | Wholesale Borrowing | Intercompany Loan",
      "principal":    "number (₦M)",
      "outstanding":  "number (₦M)",
      "interestRate": "number (%)",
      "tenorMonths":  "number",
      "repayment":    "Monthly | Quarterly | Bullet | Revolving",
      "maturityDate": "ISO date"
    },
    "Investment": {
      "investmentId": "string (required, unique) — e.g. INV-001",
      "counterparty": "string (required)",
      "type":         "Fixed Deposit | Treasury Bills | Government Security | Commercial Paper",
      "principal":    "number (₦M)",
      "interestRate": "number (%)",
      "dateInvested": "ISO date",
      "tenorDays":    "number — maturityDate auto-calculated as dateInvested + tenorDays"
    },
    "CashAccount": {
      "accountId":  "string (required, unique) — e.g. CA-001",
      "bank":       "string (required)",
      "accountNo":  "string (required)",
      "type":       "Current | Savings | Dom (USD)",
      "currency":   "NGN | USD (default NGN)",
      "balance":    "number (₦M or $M)",
      "restricted": "boolean (default false)"
    }
  },

  "eclLogic": {
    "description": "IFRS 9 simplified ECL model — ECL = PD × LGD × EAD",
    "stageClassification": {
      "Stage1": "DPD 0–29 — 12-month ECL",
      "Stage2": "DPD 30–89 — Lifetime ECL (SICR triggered)",
      "Stage3": "DPD 90+ — Lifetime ECL (credit-impaired)"
    },
    "parameters": {
      "Stage1": { "PD_12month": "2.00%", "PD_Lifetime": "5.00%", "LGD": "45%" },
      "Stage2": { "PD_12month": "15.0%", "PD_Lifetime": "35.0%", "LGD": "55%" },
      "Stage3": { "PD_12month": "75.0%", "PD_Lifetime": "90.0%", "LGD": "65%" }
    },
    "formula": {
      "Stage1_ECL":   "PD_12month × LGD × EAD",
      "Stage2_3_ECL": "PD_Lifetime × LGD × EAD",
      "Coverage":     "Total ECL / Total EAD × 100"
    },
    "scenarioTest": "Pass pdShiftPct to /ecl/scenario or pdMultiplier to GET /ecl to stress-test PD assumptions"
  },

  "uploadTemplates": {
    "loans": {
      "filename": "loan_portfolio_template.csv",
      "headers": ["loan_id","customer_name","loan_product_type","principal_amount","outstanding","interest_rate","start_date","maturity_date","days_past_due","credit_rating"],
      "sample": [
        ["LN-001","Dangote Industries Ltd","Invoice Discounting","450","420","22","2024-01-15","2024-07-15","0","A"],
        ["LN-002","Flour Mills Nigeria Plc","Supply Chain Finance","320","310","20","2024-02-01","2024-08-01","18","A-"]
      ]
    },
    "borrowings": {
      "filename": "borrowings_template.csv",
      "headers": ["borrowing_id","lender_name","borrowing_type","principal","outstanding","interest_rate","tenor_months","repayment_schedule","maturity_date"],
      "sample": [
        ["BW-001","FCMB Ltd","Term Loan","500","420","19.5","24","Monthly","2025-06-30"]
      ]
    },
    "investments": {
      "filename": "investments_template.csv",
      "headers": ["investment_id","company_name","investment_type","principal_amount","interest_rate","date_invested","number_of_days"],
      "sample": [
        ["INV-001","Access Bank Plc","Fixed Deposit","300","22","2024-03-01","180"]
      ]
    }
  }
}
